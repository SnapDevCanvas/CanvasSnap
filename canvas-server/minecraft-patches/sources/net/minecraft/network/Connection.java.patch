             configMessage = configMessage.andThen(ctx -> ctx.pipeline().addAfter(HandlerNames.DECODER, HandlerNames.BUNDLER, newBundler));
         }
 
-        syncAfterConfigurationChange(this.channel.writeAndFlush(configMessage));
+        // Canvas start - async protocol switch
+        ChannelFuture cf = this.channel.writeAndFlush(configMessage);
+        if (io.canvasmc.canvas.GlobalConfiguration.getInstance().networking.asyncProtocolSwitch && ca.spottedleaf.moonrise.common.util.TickThread.isTickThread()) {
