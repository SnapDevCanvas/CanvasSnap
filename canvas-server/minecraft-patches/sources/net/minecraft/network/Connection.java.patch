             throw new IllegalStateException("Invalid inbound protocol: " + protocol.id());
         }
 
+        if (io.canvasmc.canvas.GlobalConfiguration.getInstance().networking.asyncProtocolSwitch && ca.spottedleaf.moonrise.common.util.TickThread.isTickThread()) this.channel.config().setAutoRead(false); // Canvas - async protocol switch
