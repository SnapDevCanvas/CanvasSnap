+        // Canvas end - async protocol switch
     }
+    // Canvas start - async protocol switch
+
+    public @Nullable ChannelFuture canvas$setupOutboundProtocolAsync(ProtocolInfo<?> protocolInfo) {
+        if (protocolInfo.flow() != this.getSending()) {
+            throw new IllegalStateException("Invalid outbound protocol: " + protocolInfo.id());
+        }
+
+        UnconfiguredPipelineHandler.OutboundConfigurationTask outboundTask =
+            UnconfiguredPipelineHandler.setupOutboundProtocol(protocolInfo);
+
+        BundlerInfo bundlerInfo = protocolInfo.bundlerInfo();
+        if (bundlerInfo != null) {
+            PacketBundleUnpacker unpacker = new PacketBundleUnpacker(bundlerInfo);
+            outboundTask = outboundTask.andThen(context ->
+                context.pipeline().addAfter("encoder", "unbundler", unpacker)
+            );
+        }
+
+        boolean isLoginProtocol = protocolInfo.id() == ConnectionProtocol.LOGIN;
+
+        ChannelFuture future = this.channel.writeAndFlush(
+            outboundTask.andThen(context -> this.sendLoginDisconnect = isLoginProtocol)
+        );
+
+        if (io.canvasmc.canvas.GlobalConfiguration.getInstance().networking.asyncProtocolSwitch) {
+            future.addListener((ChannelFutureListener) Connection::syncAfterConfigurationChange);
+            return future;
+        }
+
+        return null;
+    }
+    // Canvas end - async protocol switch
 
