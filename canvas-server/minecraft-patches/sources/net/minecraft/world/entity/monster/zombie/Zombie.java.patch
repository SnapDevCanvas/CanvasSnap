From 797ef1098eaaa50c9bf6a3ac86ebfa511db756df Mon Sep 17 00:00:00 2001
From: File <noreply+automated@papermc.io>
Date: Sun, 20 Apr 1997 15:37:42 +0200
Subject: [PATCH] canvas File Patches


diff --git a/net/minecraft/world/entity/monster/zombie/Zombie.java b/net/minecraft/world/entity/monster/zombie/Zombie.java
index aa0a34e3bae3c0d81bc87577570340d1efc46c2b..6bde60f7592fcc079c542941418d53b6977fef81 100644
--- a/net/minecraft/world/entity/monster/zombie/Zombie.java
+++ b/net/minecraft/world/entity/monster/zombie/Zombie.java
@@ -344,10 +344,15 @@ public class Zombie extends Monster {
                 int yt = y + Mth.nextInt(this.random, 7, 40) * Mth.nextInt(this.random, -1, 1);
                 int zt = z + Mth.nextInt(this.random, 7, 40) * Mth.nextInt(this.random, -1, 1);
                 BlockPos spawnPos = new BlockPos(xt, yt, zt);
+                // Canvas start - prevent reinforcement checks from loading chunks
+                if (this.level().getChunkIfLoadedImmediately(spawnPos.getX() >> 4, spawnPos.getZ() >> 4) == null) {
+                    continue;
+                }
+                // Canvas end - prevent reinforcement checks from loading chunks
                 if (SpawnPlacements.isSpawnPositionOk(type, level, spawnPos)
                     && SpawnPlacements.checkSpawnRules(type, level, EntitySpawnReason.REINFORCEMENT, spawnPos, level.getRandom())) {
                     reinforcement.setPos(xt, yt, zt);
-                    if (!level.hasNearbyAlivePlayerThatAffectsSpawning(xt, yt, zt, 7.0) // Paper - affects spawning api
+                    if (!level.canvas$hasNearbyAlivePlayerThatAffectsSpawningForZombie(xt, yt, zt, 7.0) // Paper - affects spawning api // Canvas - optimize nearby alive player checks for zombies
                         && level.isUnobstructed(reinforcement)
                         && level.noCollision(reinforcement)
                         && (reinforcement.canSpawnInLiquids() || !level.containsAnyLiquid(reinforcement.getBoundingBox()))) {
