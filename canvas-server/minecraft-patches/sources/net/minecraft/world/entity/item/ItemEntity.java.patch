From 797ef1098eaaa50c9bf6a3ac86ebfa511db756df Mon Sep 17 00:00:00 2001
From: File <noreply+automated@papermc.io>
Date: Sun, 20 Apr 1997 15:37:42 +0200
Subject: [PATCH] canvas File Patches


diff --git a/net/minecraft/world/entity/item/ItemEntity.java b/net/minecraft/world/entity/item/ItemEntity.java
index 76467ded9c4eaf368cd256d53761d87bcb489864..7bc91412ae6f113b08c37b26f4f80d1e8a2729f2 100644
--- a/net/minecraft/world/entity/item/ItemEntity.java
+++ b/net/minecraft/world/entity/item/ItemEntity.java
@@ -206,7 +206,7 @@ public class ItemEntity extends Entity implements TraceableEntity {
             boolean moved = Mth.floor(this.xo) != Mth.floor(this.getX())
                 || Mth.floor(this.yo) != Mth.floor(this.getY())
                 || Mth.floor(this.zo) != Mth.floor(this.getZ());
-            int rate = moved ? 2 : 40;
+            int rate = moved && !level().canvasConfig().entities.itemEntities.itemEntitiesWaitTwoSecondsForMergeCheckAlways ? 2 : 40; // Canvas - item entity wait 2s for merge check config
             if (this.tickCount % rate == 0 && !this.level().isClientSide() && this.isMergable()) {
                 this.mergeWithNeighbours();
             }
@@ -268,7 +268,7 @@ public class ItemEntity extends Entity implements TraceableEntity {
                     }
                     // Paper end - Fix items merging through walls
                     this.tryToMerge(entity);
-                    if (this.isRemoved()) {
+                    if (!this.isMergable()) { // Canvas - if this isn't mergeable, don't merge - we used to only check for if we are removed, ignoring if we aren't even mergeable ourselves anymore
                         break;
                     }
                 }
@@ -329,6 +329,15 @@ public class ItemEntity extends Entity implements TraceableEntity {
         return !this.getItem().canBeHurtBy(this.damageSources().inFire()) || super.fireImmune();
     }
 
+    // Canvas start - invulnerable to lightning and explosions config
+    @Override
+    public boolean isInvulnerableToBase(final DamageSource damageSource) {
+        if (level().canvasConfig().entities.itemEntities.itemEntitiesImmuneToExplosions && damageSource.is(net.minecraft.tags.DamageTypeTags.IS_EXPLOSION)) return true;
+        if (level().canvasConfig().entities.itemEntities.itemEntitiesImmuneToLightning && damageSource.is(net.minecraft.tags.DamageTypeTags.IS_LIGHTNING)) return true;
+        return super.isInvulnerableToBase(damageSource);
+    }
+
+    // Canvas end - invulnerable to lightning and explosions config
     @Override
     protected boolean shouldPlayLavaHurtSound() {
         return this.health <= 0 || this.tickCount % 10 == 0;
@@ -599,4 +608,13 @@ public class ItemEntity extends Entity implements TraceableEntity {
     public @Nullable SlotAccess getSlot(final int slot) {
         return slot == 0 ? SlotAccess.of(this::getItem, this::setItem) : super.getSlot(slot);
     }
+    // Canvas start - MC-206922
+
+    @Override
+    public void thunderHit(final ServerLevel level, final net.minecraft.world.entity.LightningBolt lightning) {
+        if (!io.canvasmc.canvas.GlobalConfiguration.getInstance().vanillaFixes.mc206922 || this.tickCount > 8) {
+            super.thunderHit(level, lightning);
+        }
+    }
+    // Canvas end - MC-206922
 }
