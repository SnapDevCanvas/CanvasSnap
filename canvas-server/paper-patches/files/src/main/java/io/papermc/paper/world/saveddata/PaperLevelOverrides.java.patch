From b0840d0ded3da0cb50eed09ce213e6989cfd2cc7 Mon Sep 17 00:00:00 2001
From: File <noreply+automated@papermc.io>
Date: Sun, 20 Apr 1997 15:37:42 +0200
Subject: [PATCH] canvas paperServer File Patches


diff --git a/src/main/java/io/papermc/paper/world/saveddata/PaperLevelOverrides.java b/src/main/java/io/papermc/paper/world/saveddata/PaperLevelOverrides.java
index 0aba139ace05262464ed79bdbf6a7772964baebf..c290e45203e4de5aa628779be2dee7e807f14979 100644
--- a/src/main/java/io/papermc/paper/world/saveddata/PaperLevelOverrides.java
+++ b/src/main/java/io/papermc/paper/world/saveddata/PaperLevelOverrides.java
@@ -28,7 +28,8 @@ public final class PaperLevelOverrides extends SavedData implements ServerLevelD
         Codec.LONG.fieldOf("game_time").forGetter(levelOverrides -> levelOverrides.gameTime),
         Codec.BOOL.fieldOf("initialized").forGetter(levelOverrides -> levelOverrides.initialized),
         LEGACY_GAME_TYPE_CODEC.fieldOf("game_type").forGetter(levelOverrides -> levelOverrides.gameType),
-        LevelSettings.DifficultySettings.CODEC.fieldOf("difficulty_settings").forGetter(levelOverrides -> levelOverrides.difficultySettings)
+        LevelSettings.DifficultySettings.CODEC.fieldOf("difficulty_settings").forGetter(levelOverrides -> levelOverrides.difficultySettings),
+        io.canvasmc.canvas.world.PerWorldDistanceConfig.CODEC.fieldOf("Canvas.Distance").forGetter(levelOverrides -> levelOverrides.canvas$distanceConfig) // Canvas - per world distance
     ).apply(instance, PaperLevelOverrides::new));
     public static final SavedDataType<PaperLevelOverrides> TYPE = new SavedDataType<>(
         Identifier.fromNamespaceAndPath(Identifier.PAPER_NAMESPACE, "level_overrides"),
@@ -44,9 +45,10 @@ public final class PaperLevelOverrides extends SavedData implements ServerLevelD
     private LevelSettings.DifficultySettings difficultySettings;
     private transient @Nullable PrimaryLevelData rootData;
     private transient ResourceKey<Level> dimension = Level.OVERWORLD;
+    public final io.canvasmc.canvas.world.PerWorldDistanceConfig canvas$distanceConfig; // Canvas - per world distance
 
     private PaperLevelOverrides() {
-        this(RespawnData.DEFAULT, 0L, false, GameType.SURVIVAL, LevelSettings.DifficultySettings.DEFAULT);
+        this(RespawnData.DEFAULT, 0L, false, GameType.SURVIVAL, LevelSettings.DifficultySettings.DEFAULT, io.canvasmc.canvas.world.PerWorldDistanceConfig.DEFAULT); // Canvas - per world distance
     }
 
     private PaperLevelOverrides(
@@ -54,13 +56,15 @@ public final class PaperLevelOverrides extends SavedData implements ServerLevelD
         final long gameTime,
         final boolean initialized,
         final GameType gameType,
-        final LevelSettings.DifficultySettings difficultySettings
+        final LevelSettings.DifficultySettings difficultySettings,
+        final io.canvasmc.canvas.world.PerWorldDistanceConfig canvas$distanceConfig // Canvas - per world distance
     ) {
         this.respawnData = respawnData.normalized();
         this.gameTime = gameTime;
         this.initialized = initialized;
         this.gameType = gameType;
         this.difficultySettings = difficultySettings;
+        this.canvas$distanceConfig = canvas$distanceConfig; // Canvas - per world distance
     }
 
     public static PaperLevelOverrides createFromLiveLevelData(final PrimaryLevelData rootData) {
@@ -69,7 +73,8 @@ public final class PaperLevelOverrides extends SavedData implements ServerLevelD
             rootData.getGameTime(),
             false,
             rootData.getGameType(),
-            new LevelSettings.DifficultySettings(rootData.getDifficulty(), rootData.isHardcore(), rootData.isDifficultyLocked())
+            new LevelSettings.DifficultySettings(rootData.getDifficulty(), rootData.isHardcore(), rootData.isDifficultyLocked()),
+            io.canvasmc.canvas.world.PerWorldDistanceConfig.DEFAULT // Canvas - per world distance
         );
     }
 
@@ -83,7 +88,8 @@ public final class PaperLevelOverrides extends SavedData implements ServerLevelD
             levelData.get("Time").asLong(0L),
             levelData.get("initialized").asBoolean(true),
             GameType.byId(levelData.get("GameType").asInt(GameType.SURVIVAL.getId())),
-            levelData.get("difficulty_settings").read(LevelSettings.DifficultySettings.CODEC).result().orElse(LevelSettings.DifficultySettings.DEFAULT)
+            levelData.get("difficulty_settings").read(LevelSettings.DifficultySettings.CODEC).result().orElse(LevelSettings.DifficultySettings.DEFAULT),
+            levelData.get("Canvas.Distance").read(io.canvasmc.canvas.world.PerWorldDistanceConfig.CODEC).resultOrPartial(io.canvasmc.canvas.GlobalConfiguration.LOGGER::error).orElse(io.canvasmc.canvas.world.PerWorldDistanceConfig.DEFAULT) // Canvas - per world distance
         );
     }
 
