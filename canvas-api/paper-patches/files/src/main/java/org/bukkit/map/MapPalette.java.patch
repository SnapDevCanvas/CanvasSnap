From 37cae791925d0dd76cb2b9752a5ab53349b1ac75 Mon Sep 17 00:00:00 2001
From: File <noreply+automated@papermc.io>
Date: Sun, 20 Apr 1997 15:37:42 +0200
Subject: [PATCH] Canvas paperApi File Patches


diff --git a/src/main/java/org/bukkit/map/MapPalette.java b/src/main/java/org/bukkit/map/MapPalette.java
index 8eed1ade296a6d6e7c2b46af972d368eb065ae1f..0b5d6b5f8fa19103db3460fc427929840e412529 100644
--- a/src/main/java/org/bukkit/map/MapPalette.java
+++ b/src/main/java/org/bukkit/map/MapPalette.java
@@ -394,9 +394,15 @@ public final class MapPalette {
         temp.getRGB(0, 0, temp.getWidth(), temp.getHeight(), pixels, 0, temp.getWidth());
 
         byte[] result = new byte[temp.getWidth() * temp.getHeight()];
+        // Pufferfish start - SIMD
+        if (!io.canvasmc.canvas.simd.SIMDDetection.isEnabled) {
         for (int i = 0; i < pixels.length; i++) {
             result[i] = matchColor(new Color(pixels[i], true));
         }
+        } else {
+            io.canvasmc.canvas.simd.VectorMapPalette.matchColorVectorized(pixels, result);
+        }
+        // Pufferfish end - SIMD
         return result;
     }
 
